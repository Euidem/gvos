APP_NAME=GVOS
APP_ENV=local
APP_KEY=
# PRODUCTION: Set APP_DEBUG=false before going live. Exposing debug output is a security risk.
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------------------------
# Database Configuration
# -------------------------
# Use mysql or pgsql depending on your local setup
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gvos
DB_USERNAME=root
DB_PASSWORD=

# PostgreSQL alternative:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=gvos
# DB_USERNAME=postgres
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# PRODUCTION: Set SESSION_SECURE_COOKIE=true when serving over HTTPS to prevent cookie theft.
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=gvos_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -------------------------
# Mail Configuration
# -------------------------
# Local / development: log driver writes emails to storage/logs (no real delivery)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@gvos.local"
MAIL_FROM_NAME="${APP_NAME}"

# Branded email theme (gvos = custom GVOS theme in resources/views/vendor/mail)
MAIL_MARKDOWN_THEME=gvos

# -------------------------
# cPanel SMTP (production)
# -------------------------
# Uncomment and fill in for live email delivery via cPanel hosting:
#
# MAIL_MAILER=smtp
# MAIL_SCHEME=ssl
# MAIL_HOST=mail.yourdomain.com
# MAIL_PORT=465
# MAIL_USERNAME=noreply@yourdomain.com
# MAIL_PASSWORD=your_email_account_password
# MAIL_FROM_ADDRESS="noreply@yourdomain.com"
# MAIL_FROM_NAME="${APP_NAME}"
#
# For cPanel TLS/STARTTLS on port 587 instead of SSL:
# MAIL_SCHEME=tls
# MAIL_PORT=587
#
# To verify the configuration, use the GVOS Mail Test tool in the Ops Console
# (/admin/mail-test — super_admin and operations_admin only).

# -------------------------
# AWS (for file storage in production)
# -------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -------------------------
# Filament Admin Panel
# -------------------------
FILAMENT_GUARD=web

# -------------------------
# GVOS Vault Encryption Key
# -------------------------
# Additional key for vault credential encryption (separate from APP_KEY)
# Generate: php artisan tinker --execute="echo base64_encode(random_bytes(32));"
VAULT_ENCRYPTION_KEY=

# -------------------------
# Vite / Frontend
# -------------------------
VITE_APP_NAME="${APP_NAME}"
